# config/secrets.env.example
# 复制为 config/secrets.env，填写真实值，永远不要提交到 Git。
# .gitignore 必须包含：config/secrets.env
#
# 命名约定（按系统类型分组）：
#   SSH_*        —— SSH 登录凭据
#   DB_*         —— 数据库凭据（DB_<产品名>_USER / DB_<产品名>_PASS）
#   CACHE_*      —— 缓存服务凭据（CACHE_<产品名>_PASS）
#   MQ_*         —— 消息队列凭据（MQ_<产品名>_USER / MQ_<产品名>_PASS）
#   MON_*        —— 监控系统凭据（MON_<产品名>_USER / MON_<产品名>_PASS）
#   WEBHOOK_*    —— Webhook 密钥
#   STORAGE_*    —— 对象存储凭据（STORAGE_<产品名>_ACCESS_KEY / _SECRET_KEY）
#
# skill 脚本中只写 ${SSH_DEFAULT_PASS}，Agent 运行时从本文件注入。
# 具体变量名由你根据自身技术栈定义，在 skill 的 required_vars 中声明。

# ── SSH ────────────────────────────────────────────────────────────
SSH_DEFAULT_USER=
SSH_DEFAULT_PASS=

# ── 数据库（按需添加你用到的数据库，遵循 DB_<产品名>_* 命名）──────
# 示例（以下变量名仅为约定示例，按你的技术栈填写实际变量）：
# DB_MYSQL_USER=
# DB_MYSQL_PASS=
# DB_POSTGRES_USER=
# DB_POSTGRES_PASS=

# ── 缓存（按需添加，遵循 CACHE_<产品名>_* 命名）──────────────────
# CACHE_REDIS_PASS=

# ── 消息队列（按需添加，遵循 MQ_<产品名>_* 命名）────────────────
# MQ_KAFKA_USER=
# MQ_KAFKA_PASS=

# ── 监控系统（按需添加，遵循 MON_<产品名>_* 命名）───────────────
# MON_ZABBIX_USER=
# MON_ZABBIX_PASS=

# ── Webhook ────────────────────────────────────────────────────────
WEBHOOK_SECRET=

# ── 对象存储（按需添加，遵循 STORAGE_<产品名>_* 命名）────────────
# STORAGE_MINIO_ACCESS_KEY=
# STORAGE_MINIO_SECRET_KEY=

# ── 通知渠道（按需添加）───────────────────────────────────────────
# NOTIFY_CHAT_ID=
